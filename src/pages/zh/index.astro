---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import { useTranslations, getLocalizedPath } from '@/i18n/ui';
import PublicationCard from '@/components/ui/PublicationCard.astro';
import BlogPostCard from '@/components/ui/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const lang = 'zh';
const t = useTranslations(lang);

// Load papers
import papers from '@/content/publications/papers.json';
const recentPapers = papers.slice(0, 3);

// Load blog posts
const allPosts = await getCollection('blog', ({ data }) => data.lang === 'zh' && !data.draft);
const recentPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);

// Load gallery
import galleryData from '@/data/gallery.json';
const featuredPhotos = galleryData.filter((p) => p.featured).slice(0, 4);

// Quick links
const quickLinks = [
  { title: t('nav.about'), desc: t('home.quick_about'), href: getLocalizedPath('/about', lang), icon: 'user' },
  { title: t('nav.publications'), desc: t('home.quick_publications'), href: getLocalizedPath('/publications', lang), icon: 'paper' },
  { title: t('nav.research'), desc: t('home.quick_research'), href: getLocalizedPath('/research', lang), icon: 'microscope' },
  { title: t('nav.blog'), desc: t('home.quick_blog'), href: getLocalizedPath('/blog', lang), icon: 'pen' },
  { title: t('nav.catalogs'), desc: t('home.quick_catalogs'), href: getLocalizedPath('/catalogs', lang), icon: 'database' },
  { title: t('nav.gallery'), desc: t('home.quick_gallery'), href: getLocalizedPath('/gallery', lang), icon: 'camera' },
];
---

<BaseLayout title={t('site.title')} description={t('site.description')} lang={lang}>
  <div class="space-y-20 sm:space-y-28">

    <!-- ═══ Hero ═══ -->
    <section class="pt-8 sm:pt-16">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8">
        <!-- Avatar -->
        <div class="shrink-0">
          <img
            src={`${import.meta.env.BASE_URL}images/avatar.jpg`}
            alt="头像"
            width="160"
            height="160"
            class="w-32 h-32 sm:w-40 sm:h-40 rounded-full object-cover
                   ring-4 ring-white dark:ring-white/10
                   shadow-xl shadow-slate-200/50 dark:shadow-black/30"
          />
        </div>

        <!-- Info -->
        <div class="text-center sm:text-left">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-heading-light dark:text-heading-dark mb-2"
              style="font-family: 'Space Grotesk', 'Inter', sans-serif;">
            陈剑星
          </h1>
          <p class="text-lg sm:text-xl text-primary-light dark:text-primary-dark font-medium mb-1">
            博士后研究员
          </p>
          <p class="text-sm sm:text-base text-text-light/60 dark:text-text-dark/60 mb-4">
            占位大学天文系
          </p>
          <p class="text-base sm:text-lg italic text-text-light/80 dark:text-text-dark/80 mb-3 max-w-xl">
            {t('home.hero_tagline')}
          </p>
          <p class="text-sm sm:text-base text-text-light/70 dark:text-text-dark/70 max-w-xl leading-relaxed">
            {t('home.hero_description')}
          </p>

          <!-- Social Links -->
          <div class="flex items-center justify-center sm:justify-start gap-4 mt-6">
            <a href="https://github.com/jianxing-chen" target="_blank" rel="noopener noreferrer"
               class="text-text-light/50 dark:text-text-dark/50 hover:text-primary-light dark:hover:text-primary-dark transition-colors"
               aria-label="GitHub">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            </a>
            <a href="https://orcid.org/0000-0000-0000-0000" target="_blank" rel="noopener noreferrer"
               class="text-text-light/50 dark:text-text-dark/50 hover:text-primary-light dark:hover:text-primary-dark transition-colors"
               aria-label="ORCID">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-1.847-1.303-3.722-3.853-3.722h-2.466z"/></svg>
            </a>
            <a href="https://ui.adsabs.harvard.edu/" target="_blank" rel="noopener noreferrer"
               class="text-text-light/50 dark:text-text-dark/50 hover:text-primary-light dark:hover:text-primary-dark transition-colors"
               aria-label="ADS">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </a>
            <a href="mailto:placeholder@university.edu"
               class="text-text-light/50 dark:text-text-dark/50 hover:text-primary-light dark:hover:text-primary-dark transition-colors"
               aria-label="Email">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Recent Publications ═══ -->
    <section>
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-2xl sm:text-3xl font-semibold text-heading-light dark:text-heading-dark">
          {t('home.recent_publications')}
        </h2>
        <a href={getLocalizedPath('/publications', lang)}
           class="text-sm font-medium text-primary-light dark:text-primary-dark hover:underline underline-offset-4 whitespace-nowrap">
          {t('home.view_all')}
        </a>
      </div>
      <div class="grid gap-4">
        {recentPapers.map((paper) => (
          <PublicationCard paper={paper} lang={lang} />
        ))}
      </div>
    </section>

    <!-- ═══ Latest Posts ═══ -->
    <section>
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-2xl sm:text-3xl font-semibold text-heading-light dark:text-heading-dark">
          {t('home.latest_posts')}
        </h2>
        <a href={getLocalizedPath('/blog', lang)}
           class="text-sm font-medium text-primary-light dark:text-primary-dark hover:underline underline-offset-4 whitespace-nowrap">
          {t('home.view_all')}
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {recentPosts.map((post) => (
          <BlogPostCard post={post} lang={lang} />
        ))}
      </div>
    </section>

    <!-- ═══ Photo Highlights ═══ -->
    <section>
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-2xl sm:text-3xl font-semibold text-heading-light dark:text-heading-dark">
          {t('home.photo_highlights')}
        </h2>
        <a href={getLocalizedPath('/gallery', lang)}
           class="text-sm font-medium text-primary-light dark:text-primary-dark hover:underline underline-offset-4 whitespace-nowrap">
          {t('home.view_all')}
        </a>
      </div>
      <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory -mx-4 px-4 scrollbar-hide">
        {featuredPhotos.map((photo) => (
          <a href={getLocalizedPath('/gallery', lang)}
             class="group relative shrink-0 w-64 sm:w-72 aspect-[3/2] rounded-xl overflow-hidden snap-start
                    ring-1 ring-black/5 dark:ring-white/10">
            <img
              src={photo.thumbnail}
              alt={photo.title[lang as keyof typeof photo.title]}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent
                        opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
            <span class="absolute bottom-3 left-3 right-3 text-sm font-medium text-white
                         opacity-0 group-hover:opacity-100 transition-opacity duration-300 truncate">
              {photo.title[lang as keyof typeof photo.title]}
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- ═══ Quick Navigation ═══ -->
    <section class="pb-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {quickLinks.map((link) => (
          <a href={link.href}
             class="group relative rounded-xl p-5
                    bg-white/60 dark:bg-white/[0.03]
                    border border-slate-200/80 dark:border-white/[0.06]
                    hover:border-primary-light/30 dark:hover:border-primary-dark/30
                    hover:shadow-lg hover:shadow-primary-light/5 dark:hover:shadow-primary-dark/5
                    hover:-translate-y-0.5
                    transition-all duration-300">
            <div class="flex items-start gap-3">
              <div class="shrink-0 w-9 h-9 rounded-lg flex items-center justify-center
                          bg-primary-light/10 dark:bg-primary-dark/10
                          text-primary-light dark:text-primary-dark">
                {link.icon === 'user' && <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>}
                {link.icon === 'paper' && <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>}
                {link.icon === 'microscope' && <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/></svg>}
                {link.icon === 'pen' && <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>}
                {link.icon === 'database' && <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/></svg>}
                {link.icon === 'camera' && <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/></svg>}
              </div>
              <div>
                <h3 class="text-sm font-semibold text-heading-light dark:text-heading-dark
                           group-hover:text-primary-light dark:group-hover:text-primary-dark transition-colors">
                  {link.title}
                </h3>
                <p class="mt-1 text-xs text-text-light/60 dark:text-text-dark/60 leading-relaxed line-clamp-2">
                  {link.desc}
                </p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
