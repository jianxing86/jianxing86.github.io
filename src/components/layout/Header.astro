---
import { useTranslations, getLocalizedPath, type TranslationKey } from '@/i18n/ui';
import ThemeToggle from '@/components/ui/ThemeToggle.astro';
import LanguageSwitch from '@/components/ui/LanguageSwitch.astro';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const navItems: Array<{
  key: TranslationKey;
  path: string;
  children?: Array<{ key: TranslationKey; hash: string }>;
}> = [
  { key: 'nav.home', path: '/' },
  { key: 'nav.about', path: '/about/', children: [
    { key: 'nav.about.cv', hash: '#cv' },
    { key: 'nav.about.publications', hash: '#publications' },
    { key: 'nav.about.news', hash: '#news' },
    { key: 'nav.about.contact', hash: '#contact' },
  ]},
  { key: 'nav.research', path: '/research/' },
  { key: 'nav.blog', path: '/blog/' },
  { key: 'nav.gallery', path: '/gallery/' },
];

const currentPath = Astro.url.pathname;

function isActive(itemPath: string): boolean {
  const localizedPath = getLocalizedPath(itemPath, lang);
  if (itemPath === '/') {
    return currentPath === localizedPath || currentPath === localizedPath.replace(/\/$/, '');
  }
  return currentPath === localizedPath || currentPath.startsWith(localizedPath);
}

const activeClass = 'bg-primary-light/10 text-primary-light dark:bg-primary-dark/10 dark:text-primary-dark font-medium';
const inactiveClass = 'text-text-light dark:text-text-dark hover:text-primary-light dark:hover:text-primary-dark hover:bg-black/5 dark:hover:bg-white/5';
---

<header
  class="sticky top-0 z-50
         bg-background-light/80 dark:bg-background-dark/80
         backdrop-blur-lg
         border-b border-black/5 dark:border-white/10
         transition-colors duration-300"
>
  <nav aria-label="Main navigation" class="max-w-5xl mx-auto px-4 sm:px-6 h-16 flex items-center">
    <!-- Desktop nav links (evenly distributed) -->
    <div class="hidden md:flex items-center flex-1 justify-evenly">
      {navItems.map((item) =>
        item.children ? (
          <div class="relative group">
            <a
              href={getLocalizedPath(item.path, lang)}
              class:list={[
                'px-3 py-1.5 rounded-md text-sm transition-colors duration-200 inline-flex items-center gap-1',
                isActive(item.path) ? activeClass : inactiveClass,
              ]}
              {...(isActive(item.path) ? { 'aria-current': 'page' } : {})}
            >
              {t(item.key)}
              <svg class="w-3 h-3 opacity-50 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <div class="absolute left-1/2 -translate-x-1/2 top-full pt-1
                        opacity-0 invisible translate-y-1
                        group-hover:opacity-100 group-hover:visible group-hover:translate-y-0
                                                group-focus-within:opacity-100 group-focus-within:visible group-focus-within:translate-y-0
                        transition-all duration-200 ease-out
                        z-50">
              <div class="min-w-[160px] py-1.5
                          bg-background-light dark:bg-background-dark
                          border border-black/10 dark:border-white/10
                          rounded-lg shadow-lg">
                {item.children.map((child) => (
                  <a
                    href={`${getLocalizedPath(item.path, lang)}${child.hash}`}
                    class="block px-4 py-2 text-sm
                           text-text-light dark:text-text-dark
                           hover:text-primary-light dark:hover:text-primary-dark
                           hover:bg-black/5 dark:hover:bg-white/5
                           transition-colors duration-150"
                  >
                    {t(child.key)}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={getLocalizedPath(item.path, lang)}
            class:list={[
              'px-3 py-1.5 rounded-md text-sm transition-colors duration-200',
              isActive(item.path) ? activeClass : inactiveClass,
            ]}
            {...(isActive(item.path) ? { 'aria-current': 'page' } : {})}
          >
            {t(item.key)}
          </a>
        )
      )}
    </div>

    <!-- Desktop utilities -->
    <div class="hidden md:flex items-center gap-1 ml-4">
      <LanguageSwitch lang={lang} />
      <ThemeToggle />
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      type="button"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="md:hidden relative w-9 h-9 flex items-center justify-center
             text-text-light dark:text-text-dark
             hover:bg-black/5 dark:hover:bg-white/10
             rounded-lg transition-colors duration-200 cursor-pointer"
    >
      <span class="hamburger-line top-line"></span>
      <span class="hamburger-line mid-line"></span>
      <span class="hamburger-line bot-line"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden transition-all duration-300 ease-in-out max-h-0 opacity-0"
  >
    <div class="px-4 pb-4 pt-2 space-y-1 border-t border-black/5 dark:border-white/10">
      {navItems.map((item) =>
        item.children ? (
          <div class="mobile-dropdown">
            <button
              type="button"
              class:list={[
                'w-full flex items-center justify-between px-3 py-2.5 rounded-md text-sm transition-colors duration-200 cursor-pointer',
                isActive(item.path) ? activeClass : inactiveClass,
              ]}
              data-dropdown-toggle
            >
              <span>{t(item.key)}</span>
              <svg class="w-3.5 h-3.5 opacity-50 transition-transform duration-200 dropdown-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="mobile-dropdown-panel overflow-hidden max-h-0 transition-all duration-200 ease-in-out">
              <a
                href={getLocalizedPath(item.path, lang)}
                class="mobile-nav-link block pl-6 pr-3 py-2 rounded-md text-sm
                       text-text-light/70 dark:text-text-dark/70
                       hover:text-primary-light dark:hover:text-primary-dark
                       hover:bg-black/5 dark:hover:bg-white/5
                       transition-colors duration-150"
              >
                {t(item.key)}
              </a>
              {item.children.map((child) => (
                <a
                  href={`${getLocalizedPath(item.path, lang)}${child.hash}`}
                  class="mobile-nav-link block pl-6 pr-3 py-2 rounded-md text-sm
                         text-text-light/70 dark:text-text-dark/70
                         hover:text-primary-light dark:hover:text-primary-dark
                         hover:bg-black/5 dark:hover:bg-white/5
                         transition-colors duration-150"
                >
                  {t(child.key)}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={getLocalizedPath(item.path, lang)}
            class:list={[
              'mobile-nav-link block px-3 py-2.5 rounded-md text-sm transition-colors duration-200',
              isActive(item.path) ? activeClass : inactiveClass,
            ]}
            {...(isActive(item.path) ? { 'aria-current': 'page' } : {})}
          >
            {t(item.key)}
          </a>
        )
      )}
      <div class="flex items-center gap-2 px-3 pt-2">
        <LanguageSwitch lang={lang} />
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<style>
  .hamburger-line {
    position: absolute;
    width: 18px;
    height: 2px;
    background-color: currentColor;
    border-radius: 1px;
    transition: all 0.3s ease;
  }
  .top-line { transform: translateY(-6px); }
  .mid-line { transform: translateY(0); }
  .bot-line { transform: translateY(6px); }

  /* Open state */
  :global(.menu-open) .top-line {
    transform: translateY(0) rotate(45deg);
  }
  :global(.menu-open) .mid-line {
    opacity: 0;
  }
  :global(.menu-open) .bot-line {
    transform: translateY(0) rotate(-45deg);
  }

  /* Mobile dropdown open chevron */
  .mobile-dropdown.open .dropdown-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    // Close mobile menu helper
    function closeMenu() {
      btn!.classList.remove('menu-open');
      btn!.setAttribute('aria-expanded', 'false');
      menu!.style.maxHeight = '0';
      menu!.style.opacity = '0';
    }

    btn.addEventListener('click', () => {
      const isOpen = btn.classList.toggle('menu-open');
      btn.setAttribute('aria-expanded', String(isOpen));
      if (isOpen) {
        menu.style.maxHeight = menu.scrollHeight + 'px';
        menu.style.opacity = '1';
      } else {
        menu.style.maxHeight = '0';
        menu.style.opacity = '0';
      }
    });

    // Mobile dropdown toggles
    menu.querySelectorAll('[data-dropdown-toggle]').forEach((toggleBtn) => {
      toggleBtn.addEventListener('click', () => {
        const dropdown = toggleBtn.closest('.mobile-dropdown');
        if (!dropdown) return;
        const panel = dropdown.querySelector('.mobile-dropdown-panel') as HTMLElement;
        if (!panel) return;

        const isOpen = dropdown.classList.toggle('open');
        if (isOpen) {
          panel.style.maxHeight = panel.scrollHeight + 'px';
        } else {
          panel.style.maxHeight = '0';
        }

        // Update parent menu max-height to accommodate expanded content
        requestAnimationFrame(() => {
          menu.style.maxHeight = menu.scrollHeight + 'px';
        });
      });
    });

    // Close mobile menu when clicking a nav link
    menu.querySelectorAll('.mobile-nav-link').forEach((link) => {
      link.addEventListener('click', () => closeMenu());
    });
  }

  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
