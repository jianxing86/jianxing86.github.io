---
import { useTranslations, getLocalizedPath } from '@/i18n/ui';
import ThemeToggle from '@/components/ui/ThemeToggle.astro';
import LanguageSwitch from '@/components/ui/LanguageSwitch.astro';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const navItems = [
  { key: 'nav.home', path: '/' },
  { key: 'nav.about', path: '/about/' },
  { key: 'nav.publications', path: '/publications/' },
  { key: 'nav.blog', path: '/blog/' },
  { key: 'nav.gallery', path: '/gallery/' },
  { key: 'nav.research', path: '/research/' },
  { key: 'nav.catalogs', path: '/catalogs/' },
];
---

<header
  class="sticky top-0 z-50
         bg-background-light/80 dark:bg-background-dark/80
         backdrop-blur-lg
         border-b border-black/5 dark:border-white/10
         transition-colors duration-300"
>
  <nav aria-label="Main navigation" class="max-w-5xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a
      href={getLocalizedPath('/', lang)}
      class="text-lg font-semibold tracking-tight
             text-heading-light dark:text-heading-dark
             hover:text-primary-light dark:hover:text-primary-dark
             transition-colors duration-200"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      {t('site.title')}
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-1">
      {navItems.map((item) => (
        <a
          href={getLocalizedPath(item.path, lang)}
          class="px-3 py-1.5 rounded-md text-sm
                 text-text-light dark:text-text-dark
                 hover:text-primary-light dark:hover:text-primary-dark
                 hover:bg-black/5 dark:hover:bg-white/5
                 transition-colors duration-200"
        >
          {t(item.key)}
        </a>
      ))}

      <div class="w-px h-5 bg-black/10 dark:bg-white/10 mx-1"></div>

      <LanguageSwitch lang={lang} />
      <ThemeToggle />
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      type="button"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="md:hidden relative w-9 h-9 flex items-center justify-center
             text-text-light dark:text-text-dark
             hover:bg-black/5 dark:hover:bg-white/10
             rounded-lg transition-colors duration-200 cursor-pointer"
    >
      <span class="hamburger-line top-line"></span>
      <span class="hamburger-line mid-line"></span>
      <span class="hamburger-line bot-line"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden transition-all duration-300 ease-in-out max-h-0 opacity-0"
  >
    <div class="px-4 pb-4 pt-2 space-y-1 border-t border-black/5 dark:border-white/10">
      {navItems.map((item) => (
        <a
          href={getLocalizedPath(item.path, lang)}
          class="block px-3 py-2.5 rounded-md text-sm
                 text-text-light dark:text-text-dark
                 hover:text-primary-light dark:hover:text-primary-dark
                 hover:bg-black/5 dark:hover:bg-white/5
                 transition-colors duration-200"
        >
          {t(item.key)}
        </a>
      ))}
      <div class="flex items-center gap-2 px-3 pt-2">
        <LanguageSwitch lang={lang} />
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<style>
  .hamburger-line {
    position: absolute;
    width: 18px;
    height: 2px;
    background-color: currentColor;
    border-radius: 1px;
    transition: all 0.3s ease;
  }
  .top-line { transform: translateY(-6px); }
  .mid-line { transform: translateY(0); }
  .bot-line { transform: translateY(6px); }

  /* Open state */
  :global(.menu-open) .top-line {
    transform: translateY(0) rotate(45deg);
  }
  :global(.menu-open) .mid-line {
    opacity: 0;
  }
  :global(.menu-open) .bot-line {
    transform: translateY(0) rotate(-45deg);
  }
</style>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    btn.addEventListener('click', () => {
      const isOpen = btn.classList.toggle('menu-open');
      btn.setAttribute('aria-expanded', String(isOpen));
      if (isOpen) {
        menu.style.maxHeight = menu.scrollHeight + 'px';
        menu.style.opacity = '1';
      } else {
        menu.style.maxHeight = '0';
        menu.style.opacity = '0';
      }
    });
  }

  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
