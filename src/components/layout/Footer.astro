---
import { useTranslations } from '@/i18n/ui';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="border-t border-black/5 dark:border-white/10 mt-20 transition-colors duration-300">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <!-- Copyright -->
      <p class="text-sm text-text-light/60 dark:text-text-dark/60">
        {t('footer.copyright')}
      </p>

      <!-- Social links -->
      <div class="flex items-center gap-3">
        <!-- GitHub -->
        <a
          href="https://github.com/jianxing-chen"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="text-text-light/40 dark:text-text-dark/40
                 hover:text-text-light dark:hover:text-text-dark
                 transition-colors duration-200"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <!-- ORCID -->
        <a
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="ORCID"
          class="text-text-light/40 dark:text-text-dark/40
                 hover:text-text-light dark:hover:text-text-dark
                 transition-colors duration-200"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-1.847-1.275-3.722-3.903-3.722h-2.416z"/>
          </svg>
        </a>
        <!-- ADS -->
        <a
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="ADS"
          class="text-text-light/40 dark:text-text-dark/40
                 hover:text-text-light dark:hover:text-text-dark
                 transition-colors duration-200"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </a>
        <!-- Email -->
        <a
          href="mailto:placeholder@example.com"
          aria-label="Email"
          class="text-text-light/40 dark:text-text-dark/40
                 hover:text-text-light dark:hover:text-text-dark
                 transition-colors duration-200"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Powered by -->
    <p class="text-center text-xs text-text-light/30 dark:text-text-dark/30 mt-6">
      {t('footer.powered_by')}
    </p>
  </div>
</footer>
